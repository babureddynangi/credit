# Credit Fraud Platform — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Database (required) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://cfadmin:localdev_password@localhost:5432/credit_fraud

# ─── LLM (optional — set MOCK_LLM=true to skip all external LLM calls) ──────
MOCK_LLM=true

# LLM_BACKEND selects the real LLM when MOCK_LLM=false
# Options: openai (default) | ollama (local, free)
LLM_BACKEND=openai

# OpenAI — used when LLM_BACKEND=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama — used when LLM_BACKEND=ollama (no API key needed)
# Install: https://ollama.com  then: ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# ─── Graph Backend (optional — set mock to skip Neo4j/Neptune) ───────────────
GRAPH_BACKEND=mock
# GRAPH_BACKEND=neo4j
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=localdev_password
# NEPTUNE_ENDPOINT=your-neptune-cluster.cluster-xxxx.us-east-1.neptune.amazonaws.com

# ─── AWS (optional — leave unset for local-only logging) ─────────────────────
# AWS_REGION=us-east-1
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/credit-fraud-cases
# AUDIT_LOG_GROUP=/credit-fraud/audit
# LLM_LOG_GROUP=/credit-fraud/llm-audit

# ─── API (optional) ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── Ray Serve (optional — leave unset to use heuristic scoring fallback) ────
# RAY_SERVE_URL=http://localhost:8265
